---
import { getSortedBlogPosts } from '@utils/posts-collection'
import Navbar from '@components/Navbar.astro'
import Footer from '@components/Footer.astro'
import HeadTags from '@components/HeadTags.astro'
import { Head } from 'astro-capo'
import '../styles/posts.css'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  id: string
  frontmatter: {
    title: string
    description: string
    pubDate: Date
    cover: ImageMetadata
    coverAlt: string
  }
  minutes: string
}

const { id, frontmatter, minutes } = Astro.props

const formattedDate = frontmatter.pubDate.toISOString().slice(0, 10)

const posts = await getSortedBlogPosts()

const index = posts.findIndex((post) => post.id === id)
const nextPost = posts[index + 1]
const prevPost = posts[index - 1]
---

<html lang='en'>
  <Head>
    <HeadTags
      title={frontmatter.title}
      description={frontmatter.description}
      image={new URL(`/posts/${id}/og.png`, Astro.site)}
      article
    />
  </Head>
  <body>
    <Navbar />
    <main class='post mx-auto w-full max-w-[750px] px-8'>
      <div class='text-dim prompt-glyph pt-16 text-sm'>
        cat ./posts/{id}.mdx
      </div>
      <h1 class='text-ink mt-3 mb-4 text-3xl font-bold tracking-tight md:text-4xl'>
        {frontmatter.title}
      </h1>
      <div class='text-faint flex gap-5 text-[12.5px]'>
        <span>{formattedDate}</span>
        <span>{minutes}</span>
      </div>
      <hr class='border-border mt-5 mb-10' />
      <Image
        src={frontmatter.cover}
        alt={frontmatter.coverAlt}
        class='border-border border'
      />
      <article class='mt-8'>
        <slot />
      </article>

      <div class='mt-14 flex flex-col gap-4 sm:flex-row sm:gap-6'>
        {
          prevPost && (
            <a
              href={`/posts/${prevPost.id}`}
              class='border-border bg-panel hover:border-accent-dim flex grow flex-col border p-4 text-sm transition-colors'
            >
              <p class='text-faint mb-1'>&larr; previous</p>
              <p class='text-ink font-semibold'>{prevPost.data.title}</p>
            </a>
          )
        }
        {
          nextPost && (
            <a
              href={`/posts/${nextPost.id}`}
              class='border-border bg-panel hover:border-accent-dim flex grow flex-col border p-4 text-right text-sm transition-colors'
            >
              <p class='text-faint mb-1'>next &rarr;</p>
              <p class='text-ink font-semibold'>{nextPost.data.title}</p>
            </a>
          )
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
