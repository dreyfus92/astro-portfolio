---
import Layout from '@layouts/Layout.astro'
import { render } from 'astro:content'
import { getSortedBlogPosts } from '@utils/posts-collection'

const posts = await getSortedBlogPosts()

const withMinutes = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post)
    return { post, minutes: remarkPluginFrontmatter.minutesRead as string }
  }),
)

const byYear = new Map<number, typeof withMinutes>()
for (const entry of withMinutes) {
  const year = entry.post.data.pubDate.getFullYear()
  byYear.set(year, [...(byYear.get(year) ?? []), entry])
}
const years = [...byYear.keys()].sort((a, b) => b - a)

const formatDate = (date: Date) => date.toISOString().slice(0, 10)
---

<Layout
  title='Paul Valladares | Blog'
  description='Blog of Paul Valladares'
  image={new URL('/og/posts.png', Astro.site)}
>
  <main class='mx-auto w-full max-w-[880px] px-8'>
    <section class='pt-22'>
      <div class='text-dim prompt-glyph text-sm'>cat ./posts/README</div>
      <h1 class='text-ink mt-3 text-3xl font-bold tracking-tight md:text-5xl'>
        Posts
      </h1>
      <p class='text-dim mt-6 max-w-[58ch]'>
        Whatever catches my interest. Coding quirks, tech discoveries,
        historical mysteries and occasional life musings. No strict schedule, no
        single topic.
      </p>
    </section>

    {
      years.map((year) => (
        <section class='mt-16'>
          <h2 class='text-dim prompt-glyph mb-6 text-sm font-medium'>
            ls <span class='text-ink'>./{year}</span>
          </h2>
          <div class='border-border bg-panel border'>
            {byYear.get(year)?.map(({ post, minutes }) => (
              <a
                href={`/posts/${post.id}`}
                class='border-border hover:bg-tint group grid grid-cols-[110px_1fr_auto] items-baseline gap-5 border-b px-5 py-3.5 text-sm last:border-b-0'
              >
                <span class='text-faint text-[12.5px]'>
                  {formatDate(post.data.pubDate)}
                </span>
                <span class='text-ink group-hover:text-accent'>
                  {post.data.title}
                </span>
                <span class='text-faint text-[12.5px]'>{minutes}</span>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </main>
</Layout>
