---
import Layout from '@layouts/Layout.astro'
import { socials } from '@utils/data'
import { Image } from 'astro:assets'
---

<Layout
  title='Paul Valladares | Socials'
  description='Links for social media of Paul Valladares'
>
  <main class='mx-auto w-full max-w-[880px] px-8'>
    <section class='pt-22'>
      <div class='text-dim prompt-glyph text-sm'>ls ./socials</div>
      <div class='mt-8 flex items-center gap-6'>
        <Image
          class='border-border h-[88px] w-[88px] rounded-full border'
          src='https://avatars.githubusercontent.com/u/85648028?v=4'
          alt='Paul Valladares'
          inferSize={true}
          loading='eager'
        />
        <div>
          <h1 class='text-ink text-2xl font-bold tracking-tight md:text-3xl'>
            Paul Valladares
          </h1>
          <p class='text-dim mt-1'>
            Full-stack dev &amp; open source maintainer — based in Mexico
          </p>
        </div>
      </div>
    </section>

    <div class='border-border bg-panel mt-12 max-w-[640px] border'>
      {
        socials.map((social) => (
          <a
            href={social.url}
            target='_blank'
            rel='noreferrer'
            aria-label={social.ariaLabel}
            class='border-border hover:bg-tint group flex items-baseline justify-between border-b px-5 py-4 text-sm last:border-b-0'
          >
            <span class='text-ink group-hover:text-accent'>
              <span class='text-accent'>▪ </span>
              {social.name}
            </span>
            <span class='text-faint text-[12.5px]'>↗</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
