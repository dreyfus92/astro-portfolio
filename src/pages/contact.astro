---
import Layout from '@layouts/Layout.astro'
---

<Layout title='Paul Valladares | Contact'>
  <main class='mx-auto w-full max-w-[880px] px-8'>
    <section class='pt-22'>
      <div class='text-dim prompt-glyph text-sm'>mail -s "hello"</div>
      <h1 class='text-ink mt-3 text-3xl font-bold tracking-tight md:text-5xl'>
        Contact
      </h1>
      <p class='text-dim mt-6 max-w-[58ch]'>
        Got a project, a bug, or a package that needs a diet? Fill this in and
        it lands in my inbox.
      </p>
    </section>

    <form
      class='border-border bg-panel mt-12 flex max-w-[640px] flex-col gap-5 border p-8'
      action='https://getform.io/f/0317a7a6-6baa-4a9e-98c3-7717e70bce41'
      method='POST'
    >
      <label class='text-dim flex flex-col gap-2 text-[13px]'>
        <span><span class='text-accent'>$</span> name</span>
        <input
          type='text'
          name='name'
          placeholder='Jane Doe'
          required
          class='bg-bg border-border text-ink placeholder:text-faint focus:border-accent-dim border p-2.5 outline-none'
        />
      </label>
      <label class='text-dim flex flex-col gap-2 text-[13px]'>
        <span><span class='text-accent'>$</span> email</span>
        <input
          type='email'
          name='email'
          placeholder='jane.doe@example.com'
          required
          class='bg-bg border-border text-ink placeholder:text-faint focus:border-accent-dim border p-2.5 outline-none'
        />
      </label>
      <label class='text-dim flex flex-col gap-2 text-[13px]'>
        <span><span class='text-accent'>$</span> subject</span>
        <select
          name='subject'
          required
          class='bg-bg border-border text-ink focus:border-accent-dim border p-2.5 outline-none'
        >
          <option value='General'>General</option>
          <option value='Freelance Work'>Freelance Work</option>
          <option value='Collaboration'>Collaboration</option>
          <option value='Job Opportunity'>Job Opportunity</option>
          <option value='Other'>Other</option>
        </select>
      </label>
      <label class='text-dim flex flex-col gap-2 text-[13px]'>
        <span><span class='text-accent'>$</span> message</span>
        <textarea
          name='message'
          placeholder='Hello, I am Jane Doe...'
          required
          class='bg-bg border-border text-ink placeholder:text-faint focus:border-accent-dim h-48 resize-none border p-2.5 outline-none'
        ></textarea>
      </label>
      <button
        type='submit'
        class='border-accent-dim text-accent hover:bg-accent hover:text-bg w-fit cursor-pointer border px-6 py-2 font-semibold transition-colors'
      >
        send ⏎
      </button>
    </form>
  </main>
</Layout>
