---
import HeadTags from '@components/HeadTags.astro'
import { Head } from 'astro-capo'

const title = 'Paul Valladares | 404'
const description = 'Personal website of Paul Valladares'
---

<html lang='en'>
  <Head>
    <HeadTags title={title} description={description} />
  </Head>
  <body>
    <main
      class='mx-auto flex min-h-screen w-full max-w-[880px] flex-col items-start justify-center px-8'
    >
      <div class='text-dim prompt-glyph text-sm'>cat {'{page}'}</div>
      <h1 class='text-ink mt-3 text-6xl font-bold tracking-tight md:text-8xl'>
        404
      </h1>
      <p class='text-dim mt-4'>
        cat: no such file or directory
      </p>
      <a
        href='/'
        class='border-accent-dim text-accent hover:bg-accent hover:text-bg mt-8 border px-6 py-2 font-semibold transition-colors'
      >
        cd ~
      </a>
    </main>
  </body>
</html>
