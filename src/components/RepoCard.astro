---
import RepoLang from './RepoLang.astro'
const { repo, link, description, language, languageColor } = Astro.props
---

<a
  class='group relative block h-56 min-w-0 w-full cursor-pointer'
  href={link}
  title={description}
>
  <div
    class='relative flex h-full min-w-0 flex-col overflow-hidden rounded-3xl border-2 border-black bg-[#646664] text-white transition group-hover:-translate-x-2 group-hover:-translate-y-2 group-hover:shadow-[8px_8px_0_0_#000]'
  >
    <!-- Default: icon + name at bottom -->
    <div
      class='flex min-h-0 min-w-0 flex-1 flex-col justify-end p-6 sm:p-8 lg:group-hover:hidden'
    >
      <span class='text-3xl sm:text-4xl' role='img' aria-hidden='true'
        ><svg
          class='h-8 w-8'
          fill='currentColor'
          viewBox='0 0 24 24'
          aria-hidden='true'
        >
          <path
            fill-rule='evenodd'
            d='M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z'
            clip-rule='evenodd'></path>
        </svg>
      </span>
      <p class='mt-4 truncate text-xl font-bold sm:text-2xl'>{repo}</p>
    </div>

    <!-- lg hover: same fixed box, description clamped with ellipsis -->
    <div
      class='pointer-events-none hidden min-h-0 min-w-0 flex-col p-6 opacity-0 sm:p-8 lg:pointer-events-none lg:absolute lg:inset-0 lg:flex lg:opacity-0 lg:transition-opacity lg:duration-150 lg:group-hover:pointer-events-auto lg:group-hover:opacity-100'
    >
      <h3 class='shrink-0 truncate text-xl font-bold sm:text-2xl'>{repo}</h3>
      <p
        class='mt-2 min-h-0 flex-1 overflow-hidden text-sm leading-snug font-medium text-white/95 sm:text-base sm:leading-relaxed lg:line-clamp-4'
      >
        {description}
      </p>
      <div class='mt-2 shrink-0'>
        <RepoLang lang={language} color={languageColor} />
      </div>
    </div>
  </div>
</a>
