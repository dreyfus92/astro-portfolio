---
import { navItems } from '../utils/navigation'

const { pathname } = Astro.url
const isActive = (route: string) =>
  route === '/' ? pathname === '/' : pathname.startsWith(route)
---

<script>
  import { navigate } from 'astro:transitions/client'
  import { navItems } from '../utils/navigation'

  // SSR + ClientRouter: programmatic navigate() works, but <a> clicks still
  // full-reload. Intercept header/nav links so clicks match keybind transitions.
  if (!document.documentElement.dataset.navInit) {
    document.documentElement.dataset.navInit = 'true'

    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest(
        'nav a[href^="/"], header > a[href^="/"]',
      ) as HTMLAnchorElement | null
      if (!link || e.defaultPrevented) return
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0)
        return

      const href = link.getAttribute('href')
      if (!href) return

      const target = new URL(href, location.origin)
      if (
        target.origin !== location.origin ||
        (target.pathname === location.pathname &&
          target.search === location.search)
      )
        return

      e.preventDefault()
      navigate(href)
    })

    document.addEventListener('keydown', (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return
      const target = e.target as HTMLElement
      if (target.closest('input, textarea, select, [contenteditable]')) return
      const item = navItems[Number(e.key) - 1]
      if (item) navigate(item.route)
    })
  }
</script>

<header
  class='border-border mx-auto flex w-full max-w-[880px] flex-col gap-2.5 border-b px-5 py-4 text-[13px] sm:flex-row sm:items-center sm:justify-between sm:px-8 sm:py-5'
>
  <a href='/' class='text-dim'>
    <b class='text-accent font-medium'>paul</b>@valladares:<span
      class='text-ink'>~</span
    >
  </a>
  <nav aria-label='Main' class='flex flex-wrap gap-x-4 gap-y-1 sm:gap-5'>
    {
      navItems.map((navItem, i) => (
        <a
          href={navItem.route}
          aria-current={isActive(navItem.route) ? 'page' : undefined}
          class:list={[
            'hover:text-accent py-1 transition-colors sm:py-0',
            isActive(navItem.route) ? 'text-ink' : 'text-dim',
          ]}
        >
          <kbd
            class='text-faint hidden font-[inherit] sm:inline'
            aria-hidden='true'
          >
            [{i + 1}]
          </kbd>
          <span class='text-faint'>./</span>{navItem.text.toLowerCase()}
        </a>
      ))
    }
  </nav>
</header>
