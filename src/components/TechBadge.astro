---
type TechBadgeProps = {
  name: string
  imgSrc: string
  altSrc: string
}

const { name, imgSrc, altSrc } = Astro.props as TechBadgeProps
---

<div class='flex items-center gap-4 duration-200 ease-in-out hover:scale-105'>
  <div
    class='flex h-[60px] w-[60px] items-center justify-center rounded-full bg-neutral-600'
  >
    <img
      src={imgSrc}
      alt={altSrc}
      width='30'
      height='30'
      loading='eager'
      decoding='async'
      class='h-[30px] w-[30px] object-contain'
    />
  </div>
  <h3 class='text-[14px] md:text-[16px]'>{name}</h3>
</div>
