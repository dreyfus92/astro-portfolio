---
const links = [
  { text: 'github', url: 'https://github.com/dreyfus92' },
  { text: 'bluesky', url: 'https://bsky.app/profile/dreyfus11.bsky.social' },
  { text: 'x', url: 'https://twitter.com/soysarcasme' },
  { text: 'linkedin', url: 'https://www.linkedin.com/in/paul-valladares/' },
  { text: 'mail', url: 'mailto:paulvi92@gmail.com' },
]
---

<footer
  aria-label='Site Footer'
  class='border-border text-faint mx-auto mt-24 flex w-full max-w-[880px] justify-between border-t px-8 py-6 text-[12.5px]'
>
  <span class='prompt-glyph'>exit 0</span>
  <span>
    {
      links.map((link, i) => (
        <>
          <a
            href={link.url}
            target='_blank'
            rel='noreferrer'
            class='text-dim hover:text-accent transition-colors'
          >
            {link.text}
          </a>
          {i < links.length - 1 && ' · '}
        </>
      ))
    }
  </span>
</footer>
